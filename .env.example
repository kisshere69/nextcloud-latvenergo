# Copy this file to .env and fill in your values
# cp .env.example .env

# Domain (DuckDNS subdomain)
NC_DOMAIN=nextcloud-YOURNAME.duckdns.org

# DuckDNS token (get from https://www.duckdns.org)
DUCKDNS_TOKEN=your-duckdns-token-here

# MariaDB
MYSQL_ROOT_PASSWORD=change-me-root
MYSQL_DATABASE=nextcloud
MYSQL_USER=nextcloud
MYSQL_PASSWORD=change-me-nextcloud

# Nextcloud admin account
NEXTCLOUD_ADMIN_USER=admin
NEXTCLOUD_ADMIN_PASSWORD=change-me-admin

# Redis (no password for local dev, add one for prod)
REDIS_HOST=redis

# Let's Encrypt
LETSENCRYPT_EMAIL=your@email.com
